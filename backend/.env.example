# Puerto en el que corre el servidor Express
PORT=3001

# Host de la base de datos MySQL
DB_HOST=127.0.0.1

# Puerto de MySQL (por defecto 3306)
DB_PORT=3306

# Nombre de la base de datos
DB_NAME=gestion_correspondencia

# Usuario de la base de datos
DB_USER=root

# Contraseña de la base de datos
DB_PASS=tu_password_aqui

# Secreto para firmar access tokens (vida corta).
# Usa un valor largo y aleatorio en producción (ej: openssl rand -hex 64)
JWT_SECRET=tu_secreto_jwt_aqui

# Duración del access token (corta: 15m, 1h, etc.)
JWT_EXPIRES_IN=15m

# Secreto para firmar refresh tokens (debe ser DIFERENTE a JWT_SECRET)
# Usa un valor largo y aleatorio en producción (ej: openssl rand -hex 64)
JWT_REFRESH_SECRET=tu_secreto_refresh_aqui

# Duración del refresh token (larga: 7d, 30d, etc.)
JWT_REFRESH_EXPIRES_IN=7d

# URL completa de conexión a MySQL para Prisma.
# Formato: mysql://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL="mysql://root:tu_password_aqui@127.0.0.1:3306/gestion_correspondencia"

# URL de producción del frontend (para configurar CORS correctamente).
# En desarrollo local, dejar vacío o comentado.
FRONTEND_URL=
